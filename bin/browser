#!/bin/sh
# browser — startet einen Browser. Unter dwm (Super+B) direkt, vom TTY/tmux
# per Single-Application-X (kein Desktop, kein WM; X lebt nur, solange der
# Browser laeuft — beim Schliessen faellt man zurueck in TTY/tmux).
#
# Reihenfolge (leicht -> schwer):
#   luakit   (WebKitGTK, vim-artig: o = URL, t = Tab, / = suchen) — Standard
#   badwolf  (WebKitGTK, minimal)
#   surf     (suckless, Strg-g = URL eingeben)
#   firefox  NUR mit --firefox erzwungen: schwer (~500 MB), aber die einzige
#            Engine, an der Bank-Logins/2FA verlaesslich nicht scheitern.
#
# Zum blossen Nachschlagen ist w3m im tmux schneller als das alles hier.
#
# Aufruf:
#   browser [URL]
#   browser --firefox [URL]
usage(){ echo "Aufruf: browser [--firefox] [URL]" >&2; exit 1; }

FORCE_FF=0
case "${1:-}" in
  --firefox) FORCE_FF=1; shift ;;
  -h|--help) usage ;;
esac
URL="${1:-}"

have(){ command -v "$1" >/dev/null 2>&1; }

# --- Browser waehlen ------------------------------------------------------
# firefox-esr installiert das Binary teils als 'firefox', teils als 'firefox-esr'.
find_ff(){ for f in firefox-esr firefox; do have "$f" && { echo "$f"; return 0; }; done; return 1; }

BR=""
if [ "$FORCE_FF" -eq 1 ]; then
  BR=$(find_ff) || { echo "firefox(-esr) nicht installiert." >&2; exit 1; }
else
  for c in luakit badwolf surf; do
    if have "$c"; then BR="$c"; break; fi
  done
  if [ -z "$BR" ]; then
    if BR=$(find_ff); then
      echo "Kein leichter Browser (luakit/badwolf/surf) gefunden — nehme $BR." >&2
    else
      echo "Kein Browser gefunden. Installiere luakit (oder badwolf/surf)." >&2
      exit 1
    fi
  fi
fi

# --- GMA 3150: die Bremse NUR fuer WebKit, nicht fuer Firefox --------------
# WEBKIT_DISABLE_COMPOSITING_MODE + LIBGL_ALWAYS_SOFTWARE sind fuer WebKitGTK
# (luakit, badwolf, surf) noetig: laesst man den Compositor dort anlaufen, gibt
# es auf der GMA 3150 weisse Seiten oder Abstuerze.
#
# Fuer FIREFOX sind sie dagegen schaedlich. LIBGL_ALWAYS_SOFTWARE schaltet jede
# vorhandene Beschleunigung ab und zwingt ihn, alles in Software zu rechnen —
# auf einem 1,66-GHz-Atom ist das der Unterschied zwischen "zaeh" und
# "unbenutzbar". Firefox bringt seine eigene Notloesung mit und kommt allein
# zurecht. Real aufgefallen (12.7.2026): unter dwm, wo Firefox direkt und ohne
# diese Variablen gestartet wurde, war er spuerbar schneller als ueber 'browser'.
case "$BR" in
  firefox|firefox-esr)
    : ;;   # Bremse aus. Firefox regelt das selbst.
  *)
    export WEBKIT_DISABLE_COMPOSITING_MODE=1
    export LIBGL_ALWAYS_SOFTWARE=1
    ;;
esac
BRPATH="$(command -v "$BR")"

# --- dbus: der Grund, warum hier monatelang gar nichts startete ------------
# luakit UND firefox sind gegen libdbus gelinkt. Ohne laufenden Session-Bus
# beenden sie sich beim Start SOFORT und STILL — keine Fehlermeldung, nichts im
# Xorg-Log ausser "Server terminated successfully". Man sucht sich tot.
#
# 'dbus-run-session' startet einen Bus, der nur so lange lebt wie der Browser.
# Damit braucht es KEINEN dauerhaften dbus-Dienst — auf einer 2-GB-Kiste
# genau richtig. Voraussetzung ist das Paket 'dbus' (nicht nur 'dbus-x11',
# das liefert bloss dbus-launch ohne den Daemon dahinter).
#
# ACHTUNG: hier steht bewusst KEIN '--' hinter dbus-run-session. startx zerlegt
# seine eigene Argumentliste am ersten '--' und haelt alles dahinter fuer
# X-Server-Optionen. Ein 'dbus-run-session -- luakit' fuehrt darum zu
#   Fatal server error: Unrecognized option: '/usr/bin/luakit'
# Das '--' ist ohnehin nur noetig, wenn der Befehl mit einem Bindestrich
# beginnt. Tut er nicht.
if have dbus-run-session; then
  DBUS="dbus-run-session"
else
  DBUS=""
  echo "WARNUNG: dbus-run-session fehlt. luakit/firefox starten damit gar nicht." >&2
  echo "         sudo xbps-install -y dbus" >&2
fi

# --- Laeuft schon X? Dann direkt starten ---------------------------------
# Ohne das wuerde startx einen zweiten X-Server hochziehen — auf dem N450 der
# sichere Weg ins Chaos.
if [ -n "${DISPLAY:-}" ]; then
  if [ -n "$URL" ]; then
    exec $DBUS "$BRPATH" "$URL"
  elif [ "$BR" = surf ]; then
    exec $DBUS "$BRPATH" "https://start.duckduckgo.com/"
  else
    exec $DBUS "$BRPATH"
  fi
fi

# --- Ab hier: kein X (TTY/tmux) -> Single-Application-X ------------------
# --- Voraussetzung: startx / xinit ---------------------------------------
if ! have startx; then
  echo "startx fehlt (xorg-xinit/xinit). Ueber dwm-nb30/install.sh installieren." >&2
  exit 1
fi

# --- freien Display finden ------------------------------------------------
d=1
while [ -e "/tmp/.X11-unix/X$d" ]; do d=$((d + 1)); done

# --- als Single-App starten ----------------------------------------------
# WICHTIG — hier lag der Fehler, der monatelang niemandem auffiel:
#
# Frueher stand hier
#     startx /bin/sh -c "$CMD" -- ":$d"
# und $CMD war ein String wie "setxkbmap de; exec luakit https://orf.at".
# startx ZERLEGT seine Argumente aber an den Leerzeichen und zerstoert dabei
# die Anfuehrungszeichen. Bei 'sh -c' kam nur noch das erste Wort an. Der
# Browser wurde also NIE gestartet — 'setxkbmap' lief, endete, X machte zu.
#
# Nachgewiesen mit 'startx /bin/sh -c "sleep 8"': daraus wurde
#     sleep: fehlender Operand
# Die 8 war unterwegs verschwunden.
#
# Deshalb: kein Befehls-String, sondern eine echte SKRIPTDATEI. Daran kann
# startx nichts zerlegen. Das ist auch der Grund, warum ~/.xinitrc eine Datei
# ist und kein String.
#
# (Unter dwm fiel das nie auf: dort lief immer schon ein X, also griff der
# Zweig ganz oben mit $DISPLAY, und dieser hier wurde nie betreten.)
XRC="$(mktemp /tmp/browser-x.XXXXXX)"
BRLOG=/tmp/browser-last.log       # immer mitschreiben, s.u.
{
  echo '#!/bin/sh'
  echo 'setxkbmap de 2>/dev/null'          # de-Layout fuer URL-Zeile und Logins
  # Der Browser schreibt seine eigenen Meldungen mit. Ohne das sind sie weg,
  # sobald X den Bildschirm uebernimmt — und man raetselt, warum "nichts geht".
  if [ -n "$URL" ]; then
    echo "exec $DBUS \"$BRPATH\" \"$URL\" 2>>$BRLOG"
  elif [ "$BR" = surf ]; then
    echo "exec $DBUS \"$BRPATH\" 'https://start.duckduckgo.com/' 2>>$BRLOG"
  else
    echo "exec $DBUS \"$BRPATH\" 2>>$BRLOG"
  fi
} > "$XRC"
chmod +x "$XRC"

: > "$BRLOG"                      # frisch anfangen, nicht anhaeufen
echo ">>> $BR startet (Display :$d). Browser schliessen -> zurueck ins Terminal." >&2
echo ">>> Meldungen des Browsers landen in $BRLOG" >&2
startx "$XRC" -- ":$d" 2>>"$BRLOG"
RC=$?
rm -f "$XRC"
exit $RC
